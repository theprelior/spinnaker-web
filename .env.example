# Bu dosyayı .env olarak kopyalayın ve değerleri değiştirin:
#   cp .env.example .env

# JWT imzalama anahtarı — uzun ve rastgele bir string kullanın:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET

# Kayıt açık mı? İlk kullanıcıları oluşturduktan sonra false yapın.
ALLOW_REGISTRATION=true

# SpiNNaker2 ortamı için ek env değişkenleri (boş bırakılabilir)
SPINNAKER_PYTHONPATH=

# Job limitleri
MAX_JOBS_PER_HOUR=10
JOB_TIMEOUT_SECONDS=300
JOB_MEMORY_MB=512
